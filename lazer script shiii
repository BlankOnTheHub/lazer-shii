local function toggleAnim(b, state, textOn, textOff)
	b.Text = state and textOn or textOff
	TS:Create(b, TweenInfo.new(0.3), {TextColor3 = state and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(235, 90, 90)}):Play()
end

b3.MouseButton1Click:Connect(doEggs)
b4.MouseButton1Click:Connect(function() autoEgg = not autoEgg toggleAnim(b4, autoEgg, "AUTO EGG: ON", "AUTO EGG: OFF") end)
b5.MouseButton1Click:Connect(function() clearEffects = not clearEffects toggleAnim(b5, clearEffects, "KILL EFFECTS: ON", "KILL EFFECTS: OFF") end)

local function makeBtn(txt, yOffset, color)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, -20, 0, 30)
	b.Position = UDim2.new(0, 10, 0, yOffset)
	b.BackgroundColor3 = Color3.fromRGB(43, 45, 51)
	b.Font = Enum.Font.SourceSansSemibold
	b.Text = txt
	b.TextColor3 = color or Color3.fromRGB(240, 240, 240)
	b.TextSize = 14
	b.Parent = f
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
	
	b.MouseEnter:Connect(function() TS:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(55, 60, 68)}):Play() end)
	b.MouseLeave:Connect(function() TS:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(43, 45, 51)}):Play() end)
	return b
end

local function toggleAnim(b, state, textOn, textOff)
	b.Text = state and textOn or textOff
	TS:Create(b, TweenInfo.new(0.3), {TextColor3 = state and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(235, 90, 90)}):Play()
end


-- 6. RUNTIME POSITIONING ENGINE
task.spawn(function()
	while true do
		task.wait(0.01) -- High-performance execution frequency
		
		local char = P.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		
		if hrp then
			if selectedMode == "Auto Win Only" then
				if WinTouchPart then
					-- Rapidly teleport player directly inside the touch block
					hrp.CFrame = WinTouchPart.CFrame
					task.wait(0.03)
				end
				
			elseif selectedMode == "Auto Treadmill 25 Only" then
				local tCF = getTreadmillCFrame()
				if tCF then hrp.CFrame = tCF end
				
			elseif selectedMode == "Combo (In/Out)" then
				-- Keep the player strictly pinned to Treadmill 25
				local tCF = getTreadmillCFrame()
				if tCF then hrp.CFrame = tCF end
				
				-- Bring the touch part directly to the player and resize it to guarantee activation
				if WinTouchPart then
					pcall(function()
						WinTouchPart.Size = Vector3.new(20, 15, 20)
						WinTouchPart.CFrame = hrp.CFrame
						WinTouchPart.CanCollide = false
					end)
				end
			end
		end
	end
end)

-- 7. EFFECT PURGER & EGG MANAGER LOOP
task.spawn(function()
	local eggTimer = 0
	while true do
		task.wait(0.1)
		
		if clearEffects then
			pcall(function()
				local pGui = P:FindFirstChild("PlayerGui")
				local fxFolder = pGui and pGui:FindFirstChild("Effects")
				if fxFolder then
					fxFolder:ClearAllChildren()
				end
				if pGui:FindFirstChild("DescantPopups") then
					pGui.DescantPopups:ClearAllChildren()
				end
			end)
		end
		
		eggTimer = eggTimer + 0.1
		if autoEgg and eggTimer >= 0.7 then
			eggTimer = 0
			doEggs()
		end
	end
end)

-- 1. PURGE OLD GUI (Auto-Cleanup)
local UI_NAME = "Core_Utility_Panel"
local function purge(parent)
	local old = parent and parent:FindFirstChild(UI_NAME)
	if old then old:Destroy() end
end
if gethui then purge(gethui()) end
pcall(purge, game:GetService("CoreGui"))
pcall(purge, game:GetService("CoreGui"):FindFirstChild("RobloxGui"))
purge(P:WaitForChild("PlayerGui"))


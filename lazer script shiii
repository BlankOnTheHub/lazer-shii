-- 3. UTILITY METHODS
local function getTreadmillCFrame()
	if Treadmill25:IsA("Model") then
		return Treadmill25:GetPivot()
	elseif Treadmill25:IsA("BasePart") then
		return Treadmill25.CFrame + Vector3.new(0, 3, 0)
	end
	return nil
end

local function resetWinPart()
	if WinTouchPart and originalCFrame then
		WinTouchPart.Size = originalSize
		WinTouchPart.CFrame = originalCFrame
	end
end

local function doEggs()
	local eggArgs = {
		"EggService.open",
		{
			{name = "Egg10", type = "Egg"},
			{name = "Egg10", type = "Egg"},
			{name = "Egg10", type = "Egg"}
		}
	}
	task.spawn(pcall, RF.InvokeServer, RF, eggArgs[1], eggArgs[2])
end


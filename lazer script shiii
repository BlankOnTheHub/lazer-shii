-- 7. BACKGROUND PROCESSOR LOOP
task.spawn(function()
	local eggTimer = 0
	while true do
		task.wait(0.05) -- Fast check rate
		
		local char = P.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		
		-- Only run the treadmill assignment if you aren't currently mid-teleport win sequence
		if autoTrain and not isWinning and hrp then
			local tCF
			if Treadmill25:IsA("Model") then tCF = Treadmill25:GetPivot()
			elseif Treadmill25:IsA("BasePart") then tCF = Treadmill25.CFrame + Vector3.new(0, 3, 0) end
			if tCF then hrp.CFrame = tCF end
		end
		
		-- Handle slower background actions at intervals
		eggTimer = eggTimer + 0.05
		if eggTimer >= 0.25 then
			if autoWin and not isWinning then task.spawn(tpAndWalk) end
			
			if lowQ then
				local pGui = P:FindFirstChild("PlayerGui")
				local fxFolder = pGui and pGui:FindFirstChild("Effects")
				if fxFolder then
					local confetti = fxFolder:FindFirstChild("ConfettiFrame")
					if confetti then
						if confetti:IsA("ScreenGui") and confetti.Enabled then confetti.Enabled = false
						elseif confetti:IsA("GuiObject") and confetti.Visible then confetti.Visible = false end
					end
				end
			end
			
			if autoEgg and eggTimer >= 0.75 then
				doEggs()
			end
			
			if eggTimer >= 0.75 then eggTimer = 0 end
		end
	end
end)

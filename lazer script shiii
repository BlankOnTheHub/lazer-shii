local autoWin, autoEgg, lowQ, antiAfk, autoTrain, isWinning = false, false, false, false, false, false

-- 3. LOGIC FUNCTIONS
local function doEggs()
	local eggArgs = {
		"EggService.open",
		{
			{name = "Egg10", type = "Egg"},
			{name = "Egg10", type = "Egg"},
			{name = "Egg10", type = "Egg"}
		}
	}
	task.spawn(pcall, RF.InvokeServer, RF, eggArgs[1], eggArgs[2])
end

local function tpAndWalk()
	if isWinning then return end
	isWinning = true
	local char = P.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChild("Humanoid")
	if hrp and hum then
		-- Your working win code
		hrp.CFrame = CFrame.new(CF.Position + Vector3.new(0, 0, 6))
		task.wait(0.1)
		hum:MoveTo(CF.Position)
		task.wait(0.3)
		
		-- Safely hand control back over to the treadmill right here
		if autoTrain then
			local tCF
			if Treadmill25:IsA("Model") then tCF = Treadmill25:GetPivot()
			elseif Treadmill25:IsA("BasePart") then tCF = Treadmill25.CFrame + Vector3.new(0, 3, 0) end
			if tCF then hrp.CFrame = tCF end
		end
	end
	isWinning = false
end

local function toggleLQ()
	lowQ = not lowQ
	task.spawn(function()
		local pGui = P:FindFirstChild("PlayerGui")
		local fxFolder = pGui and pGui:FindFirstChild("Effects")
		if fxFolder and lowQ then
			local confetti = fxFolder:FindFirstChild("ConfettiFrame")
			if confetti then
				if confetti:IsA("ScreenGui") then confetti.Enabled = false
				elseif confetti:IsA("GuiObject") then confetti.Visible = false end
			end
		end
	end)
end

